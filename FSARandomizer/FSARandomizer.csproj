<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyTitle>FSA Randomizer</AssemblyTitle>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\FSALib\FSALib.csproj" />
  </ItemGroup>

  <!-- Copy FSALib actor schema JSON files so Assets.Actors is populated at runtime -->
  <ItemGroup>
    <Content Include="..\FSALib\assets\**"
             CopyToOutputDirectory="Always"
             Link="assets\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AuroraLib.Compression" Version="1.5.3" />
  </ItemGroup>

</Project>
